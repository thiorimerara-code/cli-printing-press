			want:   "/api/things?q=hello+world",
		},
		{
			name:   "empty values are dropped",
			path:   "/api/things",
			params: map[string]string{"a": "1", "b": "", "c": "3"},
			want:   "/api/things?a=1&c=3",
		},
		{
			name:   "all empty values preserves an existing query string",
