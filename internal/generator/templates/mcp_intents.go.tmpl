// handle{{pascal .Name}} runs the {{.Name}} intent: {{.Description}}
func handle{{pascal .Name}}(ctx context.Context, req mcplib.CallToolRequest) (*mcplib.CallToolResult, error) {
{{- if $.HasRequiredRoles}}
	cfg, err := newMCPConfig()
	if err != nil {
