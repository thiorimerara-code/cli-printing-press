// handle{{pascal .Name}} runs the {{.Name}} recipe intent: {{.Description}}
func handle{{pascal .Name}}(ctx context.Context, req mcplib.CallToolRequest) (*mcplib.CallToolResult, error) {
	if recipeCLIPathErr != nil {
		return mcplib.NewToolResultError(fmt.Sprintf("companion CLI binary not found: %v", recipeCLIPathErr)), nil
	}

	input := req.GetArguments()
	args := []string{
{{- range .Command}}
		{{printf "%q" .}},
{{- end}}
	}
{{- range .Params}}
{{- if eq (recipeParamTypeString .Type) "boolean"}}
	args = appendRecipeBoolFlag(args, {{printf "%q" .FlagName}}, input[{{printf "%q" .InputName}}], {{.BoolDefault}})
{{- else}}
	var missing{{.GoName}} bool
	args, missing{{.GoName}} = appendRecipeStringFlag(args, {{printf "%q" .FlagName}}, input[{{printf "%q" .InputName}}], {{printf "%q" .Default}}, {{.Required}}, {{.UseEquals}})
	if missing{{.GoName}} {
		return mcplib.NewToolResultError({{printf "%q" (printf "--%s is required" .FlagName)}}), nil
	}
{{- end}}
{{- end}}
{{- if .TakesArgs}}
	if raw, _ := input["args"].(string); strings.TrimSpace(raw) != "" {
		tokens := cobratree.SplitShellArgs(raw)
		for _, token := range tokens {
			if strings.HasPrefix(token, "-") {
				return mcplib.NewToolResultError(fmt.Sprintf("flag-like argument %q not allowed in args; use structured tool parameters instead", token)), nil
			}
		}
		args = append(args, tokens...)
	}
{{- end}}

	out, err := cobratree.RunCLICommand(ctx, recipeCLIPath, args)
	if err != nil {
		return mcplib.NewToolResultError(err.Error()), nil
	}
	return mcplib.NewToolResultText(out), nil
}
