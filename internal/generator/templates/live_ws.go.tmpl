			items = []json.RawMessage{data}
		}
		storeMu.Lock()
		for _, item := range items {
			if err := st.UpsertStreamMetadata("{{.Streaming.Metadata.EffectivePrimaryKey}}", status, item); err != nil {
				storeMu.Unlock()
				return total, err
			}
			total++
		}
		storeMu.Unlock()
	}
	return total, nil
}

