func (c Client) Run(ctx context.Context, handle func(json.RawMessage) error, record func(Event)) error {
	if strings.TrimSpace(c.URL) == "" {
		return fmt.Errorf("websocket URL is required")
	}
	minBackoff := c.MinBackoff
	if minBackoff <= 0 {
		minBackoff = time.Second
	}
	maxBackoff := c.MaxBackoff
	if maxBackoff <= 0 {
		maxBackoff = 30 * time.Second
	}
	if maxBackoff < minBackoff {
		maxBackoff = minBackoff
	}

	backoff := minBackoff
	for attempt := 1; ; attempt++ {
		if err := ctx.Err(); err != nil {
			return err
		}

		conn, _, err := websocket.DefaultDialer.DialContext(ctx, c.URL, c.Header)
		if err != nil {
			emit(record, Event{Type: "disconnect", Reason: "dial_error", Attempt: attempt, Detail: err.Error(), At: time.Now().UTC()})
			if err := sleep(ctx, backoff); err != nil {
				return err
			}
			backoff = nextBackoff(backoff, maxBackoff)
			continue
		}
		emit(record, Event{Type: "connect", Reason: "dial_ok", Attempt: attempt, At: time.Now().UTC()})
		backoff = minBackoff
		done := make(chan struct{})
		go func() {
			select {
			case <-ctx.Done():
				_ = conn.Close()
			case <-done:
			}
		}()

		if strings.TrimSpace(c.SubscribePayload) != "" {
			if err := conn.WriteMessage(websocket.TextMessage, []byte(c.SubscribePayload)); err != nil {
				close(done)
				emit(record, Event{Type: "disconnect", Reason: "subscribe_error", Attempt: attempt, Detail: err.Error(), At: time.Now().UTC()})
				_ = conn.Close()
				if err := sleep(ctx, backoff); err != nil {
					return err
				}
				backoff = nextBackoff(backoff, maxBackoff)
				continue
			}
			emit(record, Event{Type: "subscribe", Reason: "sent", Attempt: attempt, At: time.Now().UTC()})
		}

		for {
			_, data, err := conn.ReadMessage()
			if err != nil {
				close(done)
				emit(record, Event{Type: "disconnect", Reason: "read_error", Attempt: attempt, Detail: err.Error(), At: time.Now().UTC()})
				_ = conn.Close()
				break
			}
			for _, frame := range SplitFrame(data, c.Framing) {
