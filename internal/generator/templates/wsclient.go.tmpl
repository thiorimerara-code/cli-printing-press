func SplitFrame(data []byte, framing string) [][]byte {
	switch framing {
	case FramingNDJSON:
		var out [][]byte
		for _, line := range bytes.Split(data, []byte{'\n'}) {
			line = bytes.TrimSpace(line)
			if len(line) == 0 {
				continue
